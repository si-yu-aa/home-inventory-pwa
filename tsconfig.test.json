{
  "extends": "./tsconfig.app.json",
  "compilerOptions": {
    "allowImportingTsExtensions": false,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noEmit": false,
    "outDir": ".tmp-tests",
    "rootDir": ".",
    "types": ["node"],
    "verbatimModuleSyntax": false
  },
  "include": ["src/domain/**/*.ts", "src/features/**/*.ts", "src/lib/**/*.ts", "tests/**/*.ts"]
}
